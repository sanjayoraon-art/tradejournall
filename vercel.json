{
    "routes": [
        {
            "src": "/sitemap.xml",
            "dest": "/api/sitemap"
        }
    ],
    "rewrites": [
        {
            "source": "/blog/:slug",
            "destination": "/api/render-blog?slug=$slug"
        },
        {
            "source": "/((?!api/|game-page\\.html|buy-the-dip\\.html).*)",
            "destination": "/index.html"
        }
    ]
}